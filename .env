# Supabase 데이터베이스 연결 설정
# 다음 정보를 Supabase Dashboard에서 확인하고 입력하세요:
# Settings → Database → Connection string (pooler)

# 호스트명 (pooler 엔드포인트)
DB_HOST=aws-1-ap-northeast-2.pooler.supabase.com

# 사용자명 (프로젝트 ID 포함 필수!)
# 형식: postgres.<프로젝트_id>
# 예시: postgres.abc123xyz
DB_USER=postgres

# 비밀번호
DB_PASSWORD=aivle202609!@#

